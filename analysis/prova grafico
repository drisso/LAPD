plot_speed_spike_timeseries <- function(predictions, 
                                        data_w_dist, 
                                        neuron_id = 1, 
                                        frame_range = c(1, 1000), 
                                        threshold = 0.15) { # Default aggiornato a 0.15
  
  Z_obs  <- predictions$actual_spikes    # [K x T]
  Z_pred <- predictions$predicted_probs # [K x T]
  dt_ms  <- predictions$time_ms
  
  K <- nrow(Z_obs)
  T_total <- ncol(Z_obs)
  
  # 1. Finestra temporale
  if (is.null(frame_range)) {
    frame_range <- c(1, T_total)
  }
  start_frame <- max(1, frame_range[1])
  end_frame   <- min(T_total, frame_range[2])
  frames_idx  <- start_frame:end_frame
  
  time_sec <- (frames_idx * dt_ms) / 1000
  
  # 2. Interpolazione velocità sui frame considerati
  speed_interp <- approx(
    x = data_w_dist$time, 
    y = data_w_dist$speed_spline, 
    xout = (1:T_total) * dt_ms, 
    rule = 2
  )$y[frames_idx]
  
  df_speed <- data.frame(
    Time = time_sec,
    Speed = speed_interp
  )
  
  # 3. Estrazione Spike Osservati e Binarizzazione Predizioni a Soglia = 0.15
  obs_spikes  <- Z_obs[neuron_id, frames_idx]
  pred_probs  <- Z_pred[neuron_id, frames_idx]
  pred_spikes <- ifelse(pred_probs >= threshold, 1, 0)
  
  # 4. Calcolo posizioni verticali sopra la curva di velocità
  max_speed <- max(df_speed$Speed, na.rm = TRUE)
  min_speed <- min(df_speed$Speed, na.rm = TRUE)
  speed_range <- ifelse(max_speed == min_speed, 1, max_speed - min_speed)
  
  y_obs_min <- max_speed + 0.05 * speed_range
  y_obs_max <- max_speed + 0.15 * speed_range
  
  y_pred_min <- max_speed + 0.18 * speed_range
  y_pred_max <- max_speed + 0.28 * speed_range
  
  # 5. Creazione Dataframe Unificato per gli Segmenti (Evita errori se 0 spike)
  df_obs_spikes <- data.frame(
    Time = time_sec[obs_spikes == 1],
    ymin = y_obs_min,
    ymax = y_obs_max,
    Type = "Spike Osservato (Z = 1)"
  )
  
  df_pred_spikes <- data.frame(
    Time = time_sec[pred_spikes == 1],
    ymin = y_pred_min,
    ymax = y_pred_max,
    Type = sprintf("Spike Predetto (P >= %.2f)", threshold)
  )
  
  df_segments <- rbind(df_obs_spikes, df_pred_spikes)
  
  # 6. Rendering ggplot2
  p <- ggplot() +
    # Curve della Velocità (Grigio Scuro)
    geom_line(data = df_speed, aes(x = Time, y = Speed), color = "#34495E", linewidth = 0.7) +
    
    # Layer delle barre degli Spike (Rosso = Osservato, Blu = Predetto)
    {
      if (nrow(df_segments) > 0) {
        geom_segment(
          data = df_segments,
          aes(x = Time, xend = Time, y = ymin, yend = ymax, color = Type),
          linewidth = 0.8
        )
      }
    } +
    
    scale_color_manual(
      name = "Evento",
      values = setNames(
        c("#E74C3C", "#2980B9"), 
        c("Spike Osservato (Z = 1)", sprintf("Spike Predetto (P >= %.2f)", threshold))
      )
    ) +
    
    labs(
      title = sprintf("Velocità vs. Spikes Realizzati e Predetti - Neurone %d", neuron_id),
      subtitle = sprintf("Finestra: %d-%d frame | Soglia P(Spike) = %.2f | Predetti: %d | Osservati: %d", 
                         start_frame, end_frame, threshold, nrow(df_pred_spikes), nrow(df_obs_spikes)),
      x = "Tempo (secondi)",
      y = "Velocità (cm/s)"
    ) +
    
    theme_minimal() +
    theme(
      plot.title = element_text(face = "bold", size = 12, hjust = 0.5),
      plot.subtitle = element_text(size = 9.5, hjust = 0.5, color = "gray30"),
      axis.title = element_text(face = "bold", size = 10),
      panel.grid.minor = element_blank(),
      legend.position = "top"
    )
  
  return(p)
}

